# Pixabay API key — get a free one at https://pixabay.com/api/docs/
# Copy this file to ".env" and paste your key below.
# Users can also enter a key in the app UI (stored in their browser only).
VITE_PIXABAY_API_KEY=

# Firebase web app config — copy from Firebase console > Project settings > Your apps.
# These are public client values (shipped to the browser), not secrets.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
